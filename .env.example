# ── Database ──────────────────────────────────────────────
POSTGRES_USER=moneypulse
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=moneypulse
DATABASE_URL=postgresql://moneypulse:changeme_in_production@localhost:5432/moneypulse

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Ollama (AI) ──────────────────────────────────────────
# Default: Ollama running in Docker Compose
# Override: point to external machine with OLLAMA_URL
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# ── PDF Parser ────────────────────────────────────────────
PDF_PARSER_URL=http://localhost:5000

# ── File Storage ─────────────────────────────────────────
UPLOAD_DIR=/data/uploads
WATCH_FOLDER_DIR=/config/watch-folder
MAX_UPLOAD_SIZE_MB=50

# ── Next.js ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
