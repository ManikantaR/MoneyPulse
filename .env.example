# ── Database ──────────────────────────────────────────────
POSTGRES_USER=moneypulse
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=moneypulse
DATABASE_URL=postgresql://moneypulse:changeme_in_production@localhost:5432/moneypulse

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://:changeme_redis@localhost:6379
REDIS_PASSWORD=changeme_redis

# ── API ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=GENERATE_WITH_openssl_rand_hex_64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Ollama (AI) ──────────────────────────────────────────
# NAS deployment: set to the Mac's LAN IP — use the IP, NOT mDNS (*.local
# does not resolve inside a Docker bridge container).  Reserve the IP in your
# router's DHCP settings so it never changes.
# See docs/ollama-on-mac.md for full setup and the layered connectivity test.
# Example: OLLAMA_URL=http://10.140.2.50:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b
# Health probe cache TTL and timeout (optional, defaults shown):
# OLLAMA_HEALTH_CACHE_TTL_MS=30000
# OLLAMA_PROBE_TIMEOUT_MS=2000

# ── PDF Parser ────────────────────────────────────────────
PDF_PARSER_URL=http://localhost:5000

# ── File Storage ─────────────────────────────────────────
UPLOAD_DIR=/data/uploads
WATCH_FOLDER_DIR=/config/watch-folder
MAX_UPLOAD_SIZE_MB=50

# ── Next.js ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ── Cookies ──────────────────────────────────
# Set to 'false' for HTTP-only deployments (e.g., local VLAN without HTTPS)
# Default: secure cookies enabled in production
COOKIE_SECURE=true

# ── Encryption ───────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_hex_32

# ── Sync (Phase 6.7) ─────────────────────────────────────
# URL of the Firebase Cloud Function sync receiver endpoint (set after moneypulse-web deploy)
FIREBASE_SYNC_ENDPOINT=https://REGION-PROJECT_ID.cloudfunctions.net/syncReceiver
# HMAC signing secret — must match value in GCP Secret Manager (SYNC_SIGNING_SECRET)
# Generate with: openssl rand -base64 48
SYNC_SIGNING_SECRET=GENERATE_WITH_openssl_rand_base64_48
# Alias pseudonymization secret — never rotate without a data migration
# Generate with: openssl rand -base64 48
ALIAS_SECRET=GENERATE_WITH_openssl_rand_base64_48

# ── Home Assistant webhook ───────────────────────────────────
# Comma-separated HA host IPs/hostnames the webhook is allowed to reach.
# Without this, isUrlSafe() blocks LAN/private addresses (SSRF guard) and
# the MoneyPulse → HA notification webhook is silently dropped.
# Example: HA_WEBHOOK_ALLOWED_HOSTS=10.140.2.145,homeassistant.local
HA_WEBHOOK_ALLOWED_HOSTS=
