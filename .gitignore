# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
.turbo/
*.tsbuildinfo

# Environment / secrets — NEVER commit. Broad ignore + explicit allow-list.
.env
.env.*
!.env.example
# .env.production is intentionally tracked: it holds ONLY public NEXT_PUBLIC_* values
# (these are baked into the browser bundle anyway). NEVER put a real secret here.
!.env.production
*.pem
*.key
*.p12
*-credentials.json
*serviceAccount*.json

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Testing
coverage/
.nyc_output/

# Docker
docker-compose.override.yml

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
*.egg-info/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Uploads & Archives (configured via Docker volumes)
config/watch-folder/**/.*archived/
!config/watch-folder/.gitkeep

# Database dumps
*.sql.gz
*.dump

# Misc
*.tgz
.cache/

# temp directory
.temp
.tmp
.env.bak-clean-url

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
