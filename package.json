{
  "name": "moneypulse",
  "version": "1.0.0",
  "private": true,
  "description": "MoneyPulse — Personal Finance Tracker",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @moneypulse/api run db:generate",
    "db:migrate": "pnpm --filter @moneypulse/api run db:migrate",
    "db:seed": "pnpm --filter @moneypulse/api run db:seed",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:prod": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.8.20"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp": "^8.4.0",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "picomatch@>=2.0.0 <2.3.2": "^2.3.2",
      "brace-expansion@>=1.0.0 <1.1.13": "^1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "^2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": "^5.0.5",
      "ajv@>=7.0.0-alpha.0 <8.18.0": "^8.18.0",
      "esbuild@<=0.24.2": "^0.25.0"
    }
  }
}
