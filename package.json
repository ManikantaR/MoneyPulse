{
  "name": "moneypulse",
  "version": "1.0.0",
  "private": true,
  "description": "MoneyPulse — Personal Finance Tracker",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:web": "playwright test",
    "e2e:ui": "playwright test --ui",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @moneypulse/api run db:generate",
    "db:migrate": "pnpm --filter @moneypulse/api run db:migrate",
    "db:seed": "pnpm --filter @moneypulse/api run db:seed",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:prod": "docker compose up -d",
    "docker:down": "docker compose down",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "node scripts/validate-ai-customizations.mjs && npx markdownlint-cli2 --no-globs AGENTS.md \".github/**/*.md\" \"docs/agentic/**/*.md\""
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.9.14",
    "vite": "8.0.8"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp": "^8.4.0",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "picomatch@>=2.0.0 <2.3.2": "^2.3.2",
      "brace-expansion@>=1.0.0 <1.1.13": "^1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "^2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": "^5.0.5",
      "brace-expansion@>=5.0.0 <5.0.6": "^5.0.6",
      "ajv@>=7.0.0-alpha.0 <8.18.0": "^8.18.0",
      "qs@>=6.11.1 <=6.15.1": "^6.15.2",
      "tmp@<0.2.6": "^0.2.6",
      "esbuild@<=0.24.2": "^0.25.0",
      "vite": "^8.0.8",
      "lodash": "^4.18.1",
      "fast-uri": ">=3.1.2",
      "postcss": ">=8.5.10",
      "uuid": ">=11.1.1"
    }
  }
}
